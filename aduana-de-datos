@functions_framework.cloud_event
def aduana_de_datos(cloud_event):
    data = cloud_event.data or {}
    bucket_name = data.get("bucket")
    file_name = data.get("name")
    generation = str(data.get("generation", "unknown"))
    event_type = str(data.get("eventType", ""))

    if not bucket_name or not file_name:
        logging.warning("Evento invalido: faltan bucket o name.")
        return

    if "/" not in file_name:
        logging.info("Archivo ignorado por no tener estructura brand/archivo.csv: %s", file_name)
        return

    if not file_name.lower().endswith(".csv"):
        logging.info("Archivo ignorado por no ser CSV: %s", file_name)
        return

    if event_type and "finalized" not in event_type.lower():
        logging.info("Evento ignorado por no ser finalize: %s", event_type)
        return

    raw_brand = file_name.split("/")[0]
    brand_id = sanitize_brand_id(raw_brand)

    storage_client = storage.Client(project=PROJECT_ID)
    lock_key = build_lock_key(file_name, generation)
    done_key = build_done_key(file_name, generation)

    logging.info(
        "Procesando archivo '%s' para brand_id '%s' | generation=%s",
        file_name,
        brand_id,
        generation,
    )

    try:
        if done_marker_exists(storage_client, bucket_name, done_key):
            logging.info("Archivo ya procesado previamente, se omite: %s | generation=%s", file_name, generation)
            return

        got_lock = acquire_gcs_lock(
            storage_client=storage_client,
            bucket_name=bucket_name,
            lock_key=lock_key,
            payload=f"locked:{file_name}:{generation}",
        )

        if not got_lock:
            logging.warning(
                "Otro proceso ya tomo el lock de este archivo. Se omite para evitar concurrencia: %s | generation=%s",
                file_name,
                generation,
            )
            return

        bq = bigquery.Client(project=PROJECT_ID)

        for capa in ["staging", "core", "ai"]:
            dataset_id = f"{PROJECT_ID}.{brand_id}_{capa}"
            dataset = bigquery.Dataset(dataset_id)
            dataset.location = BQ_LOCATION
            bq.create_dataset(dataset, exists_ok=True)

        try:
            raw_df = read_csv_from_gcs(bucket_name, file_name)
        except NotFound:
            logging.warning("Archivo ya no existe en GCS, se ignora el evento: %s", file_name)
            return

        raw_df = raw_df.fillna("")
        source_system = detect_source_system(raw_df, file_name)
        logging.info("Origen detectado: %s", source_system)
        log_unknown_columns(raw_df)

        canonical_df = build_canonical_dataframe(
            df=raw_df,
            source_system=source_system,
            source_file=file_name,
        )

        stg_table = f"{PROJECT_ID}.{brand_id}_staging.raw_import"

        load_cfg = bigquery.LoadJobConfig(
            write_disposition=bigquery.WriteDisposition.WRITE_TRUNCATE
        )

        bq.load_table_from_dataframe(
            canonical_df,
            stg_table,
            job_config=load_cfg,
        ).result()

        replacements = {
            "STG_TABLE": stg_table,
            "CORE_DS": f"{PROJECT_ID}.{brand_id}_core",
        }

        sql_fact_pedidos_limpios = render_sql(
