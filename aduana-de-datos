def sanitize_brand_id(raw_brand: str) -> str:
    brand = raw_brand.strip().lower().replace("-", "_")
    brand = re.sub(r"[^a-z0-9_]", "_", brand)
    brand = re.sub(r"_+", "_", brand).strip("_")

    if brand and brand[0].isdigit():
        brand = f"b_{brand}"

    if not brand:
        raise ValueError("No se pudo derivar un brand_id valido desde la ruta del archivo.")

    return brand


def normalize_header(text: str) -> str:
    text = str(text).strip().lower()
    text = unicodedata.normalize("NFKD", text).encode("ascii", "ignore").decode("utf-8")
    text = re.sub(r"[^a-z0-9]+", "_", text)
    text = re.sub(r"_+", "_", text).strip("_")
    return text


def read_csv_from_gcs(bucket_name: str, file_name: str) -> pd.DataFrame:
    storage_client = storage.Client(project=PROJECT_ID)
    bucket = storage_client.bucket(bucket_name)
    blob = bucket.blob(file_name)
    raw_bytes = blob.download_as_bytes()

    attempts = [
        {"encoding": "utf-8-sig", "sep": ","},
        {"encoding": "utf-8", "sep": ","},
        {"encoding": "latin-1", "sep": ","},
        {"encoding": "utf-8-sig", "sep": ";"},
        {"encoding": "utf-8", "sep": ";"},
        {"encoding": "latin-1", "sep": ";"},
    ]

    last_error = None
    for attempt in attempts:
        try:
            df = pd.read_csv(
                io.BytesIO(raw_bytes),
                dtype=str,
                encoding=attempt["encoding"],
                sep=attempt["sep"],
                keep_default_na=False,
            )
            if df.shape[1] >= 1:
                return df
        except Exception as e:
            last_error = e

    raise ValueError(f"No se pudo leer el CSV desde GCS: {last_error}")


def render_sql(sql_template: str, replacements: Dict[str, str]) -> str:
    sql = sql_template
    for key, value in replacements.items():
        sql = sql.replace(f"__{key}__", value)
    return sql


def run_query(bq: bigquery.Client, step_name: str, sql: str) -> None:
    logging.info("Iniciando paso: %s", step_name)
    try:
        job = bq.query(sql, location=BQ_LOCATION)
        job.result()
        logging.info("Paso OK: %s", step_name)
    except BadRequest as e:
        logging.error("BigQuery fallo en paso %s: %s", step_name, e)
        if getattr(e, "errors", None):
            for err in e.errors:
                logging.error("BQ detalle %s: %s", step_name, err)
        raise


def log_unknown_columns(df: pd.DataFrame) -> None:
    known = set()
    for aliases in COLUMN_ALIASES.values():
        for alias in aliases:
            known.add(normalize_header(alias))

    unknown = [c for c in df.columns if normalize_header(c) not in known]
    if unknown:
        logging.info("Columnas no mapeadas detectadas: %s", unknown)
    else:
        logging.info("Todas las columnas relevantes fueron reconocidas por el diccionario.")


def publish_brand_event(project_id: str, topic_id: str, brand_id: str) -> None:
    publisher = pubsub_v1.PublisherClient()
    topic_path = publisher.topic_path(project_id, topic_id)
    future = publisher.publish(topic_path, brand_id.encode("utf-8"))
    message_id = future.result()
    logging.info(
        "Mensaje Pub/Sub publicado. topic=%s brand_id=%s message_id=%s",
        topic_id,
        brand_id,
        message_id,
    )


