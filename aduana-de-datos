def build_canonical_dataframe(
    df: pd.DataFrame,
    source_system: str,
    source_file: str,
) -> pd.DataFrame:
    normalized_to_originals: Dict[str, List[str]] = {}

    for col in df.columns:
        norm = normalize_header(col)
        normalized_to_originals.setdefault(norm, []).append(col)

    result = pd.DataFrame(index=df.index)
    result["source_system"] = source_system
    result["source_file"] = source_file

    canonical_targets = [
        "order_id",
        "email",
        "billing_name",
        "shipping_name",
        "billing_phone",
        "shipping_phone",
        "phone",
        "billing_city",
        "shipping_city",
        "total",
        "created_at",
        "lineitem_name",
        "lineitem_quantity",
        "lineitem_price",
        "lineitem_total",
        "sku",
        "product_id",
        "variant_id",
        "vendor",
        "product_type",
    ]

    for canonical in canonical_targets:
        result[canonical] = ""

        aliases = COLUMN_ALIASES.get(canonical, [])
        candidate_norms = [normalize_header(a) for a in aliases]

        for norm in candidate_norms:
            if norm in normalized_to_originals:
                for original_col in normalized_to_originals[norm]:
                    values = df[original_col].fillna("").astype(str).str.strip()
                    result[canonical] = result[canonical].mask(result[canonical].eq(""), values)

    result["billing_name"] = result["billing_name"].mask(
        result["billing_name"].eq(""),
        result["shipping_name"],
    )

    result["shipping_name"] = result["shipping_name"].mask(
        result["shipping_name"].eq(""),
        result["billing_name"],
    )

    result["phone"] = result["phone"].mask(result["phone"].eq(""), result["billing_phone"])
    result["phone"] = result["phone"].mask(result["phone"].eq(""), result["shipping_phone"])

    result["billing_city"] = result["billing_city"].mask(
        result["billing_city"].eq(""),
        result["shipping_city"],
    )

    result["shipping_city"] = result["shipping_city"].mask(
        result["shipping_city"].eq(""),
        result["billing_city"],
    )

    result["email"] = result["email"].astype(str).str.strip().str.lower()
    result = result[CANONICAL_COLUMNS].fillna("")
    return result


