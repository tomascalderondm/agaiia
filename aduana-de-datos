def build_lock_key(file_name: str, generation: str) -> str:
    safe_file = re.sub(r"[^a-zA-Z0-9._/-]+", "_", file_name)
    return f"_aduana_locks/{safe_file}__{generation}.lock"


def build_done_key(file_name: str, generation: str) -> str:
    safe_file = re.sub(r"[^a-zA-Z0-9._/-]+", "_", file_name)
    return f"_aduana_done/{safe_file}__{generation}.done"


def done_marker_exists(storage_client: storage.Client, bucket_name: str, done_key: str) -> bool:
    bucket = storage_client.bucket(bucket_name)
    blob = bucket.blob(done_key)
    return blob.exists()


def acquire_gcs_lock(storage_client: storage.Client, bucket_name: str, lock_key: str, payload: str) -> bool:
    """
    Crea un lock de forma atomica.
    if_generation_match=0 => solo crea si el objeto NO existe.
    """
    bucket = storage_client.bucket(bucket_name)
    blob = bucket.blob(lock_key)

    try:
        blob.upload_from_string(
            payload,
            content_type="text/plain",
            if_generation_match=0,
        )
        return True
    except PreconditionFailed:
        return False


def write_done_marker(storage_client: storage.Client, bucket_name: str, done_key: str, payload: str) -> None:
    bucket = storage_client.bucket(bucket_name)
    blob = bucket.blob(done_key)
    blob.upload_from_string(payload, content_type="text/plain")


def safe_delete_lock(storage_client: storage.Client, bucket_name: str, lock_key: str) -> None:
    try:
        bucket = storage_client.bucket(bucket_name)
        blob = bucket.blob(lock_key)
        blob.delete()
    except Exception as e:
        logging.warning("No se pudo borrar lock %s: %s", lock_key, str(e))


