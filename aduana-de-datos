}


def detect_source_system(df: pd.DataFrame, file_name: str) -> str:
    file_hint = normalize_header(file_name)

    if "shopify" in file_hint:
        return "shopify"

    if "jumpseller" in file_hint:
        return "jumpseller"

    normalized_headers = {normalize_header(c) for c in df.columns}

    shopify_score = len(normalized_headers & SHOPIFY_SIGNATURES)
    jumpseller_score = len(normalized_headers & JUMPSELLER_SIGNATURES)

    if shopify_score > jumpseller_score and shopify_score >= 2:
        return "shopify"

    if jumpseller_score > shopify_score and jumpseller_score >= 2:
        return "jumpseller"

    return "unknown"


