                product_name,
                CASE
                  WHEN SAFE_CAST(REGEXP_REPLACE(COALESCE(lineitem_quantity_raw, ''), r'[^0-9\\-]', '') AS INT64) IS NULL
                       AND product_name IS NOT NULL AND product_name != ''
                    THEN 1
                  ELSE SAFE_CAST(REGEXP_REPLACE(COALESCE(lineitem_quantity_raw, ''), r'[^0-9\\-]', '') AS INT64)
                END AS cantidad,
                CASE
                  WHEN lineitem_price_raw IS NULL OR TRIM(lineitem_price_raw) = '' THEN NULL
                  WHEN REGEXP_CONTAINS(lineitem_price_raw, r'^\\s*\\$?\\s*[0-9]{1,3}(\\.[0-9]{3})+(,[0-9]+)?\\s*$')
                    THEN SAFE_CAST(REPLACE(REPLACE(REGEXP_REPLACE(lineitem_price_raw, r'[^0-9,\\.]', ''), '.', ''), ',', '.') AS NUMERIC)
                  WHEN REGEXP_CONTAINS(lineitem_price_raw, r'^\\s*\\$?\\s*[0-9]{1,3}(,[0-9]{3})+(\\.[0-9]+)?\\s*$')
                    THEN SAFE_CAST(REPLACE(REGEXP_REPLACE(lineitem_price_raw, r'[^0-9,\\.]', ''), ',', '') AS NUMERIC)
                  WHEN REGEXP_CONTAINS(lineitem_price_raw, r'^\\s*\\$?\\s*[0-9]+,[0-9]+\\s*$')
                    THEN SAFE_CAST(REPLACE(REGEXP_REPLACE(lineitem_price_raw, r'[^0-9,]', ''), ',', '.') AS NUMERIC)
                  ELSE SAFE_CAST(REGEXP_REPLACE(lineitem_price_raw, r'[^0-9\\.]', '') AS NUMERIC)
                END AS precio_unitario,
                CASE
                  WHEN lineitem_total_raw IS NULL OR TRIM(lineitem_total_raw) = '' THEN NULL
                  WHEN REGEXP_CONTAINS(lineitem_total_raw, r'^\\s*\\$?\\s*[0-9]{1,3}(\\.[0-9]{3})+(,[0-9]+)?\\s*$')
                    THEN SAFE_CAST(REPLACE(REPLACE(REGEXP_REPLACE(lineitem_total_raw, r'[^0-9,\\.]', ''), '.', ''), ',', '.') AS NUMERIC)
                  WHEN REGEXP_CONTAINS(lineitem_total_raw, r'^\\s*\\$?\\s*[0-9]{1,3}(,[0-9]{3})+(\\.[0-9]+)?\\s*$')
                    THEN SAFE_CAST(REPLACE(REGEXP_REPLACE(lineitem_total_raw, r'[^0-9,\\.]', ''), ',', '') AS NUMERIC)
                  WHEN REGEXP_CONTAINS(lineitem_total_raw, r'^\\s*\\$?\\s*[0-9]+,[0-9]+\\s*$')
                    THEN SAFE_CAST(REPLACE(REGEXP_REPLACE(lineitem_total_raw, r'[^0-9,]', ''), ',', '.') AS NUMERIC)
                  ELSE SAFE_CAST(REGEXP_REPLACE(lineitem_total_raw, r'[^0-9\\.]', '') AS NUMERIC)
                END AS subtotal_linea,
                sku,
                product_id,
                variant_id,
                vendor,
                product_type,
                source_system,
                source_file,
                'CLP' AS currency_code,
                created_at_raw,
                total_raw
              FROM base
            )
            SELECT
              order_id,
              email,
              nombre,
              telefono,
              city,
              total_precio,
              fecha,
              product_name,
              source_system,
              source_file,
              cantidad,
              precio_unitario,
              subtotal_linea,
              sku,
              product_id,
              variant_id,
              vendor,
              product_type,
              currency_code,
              created_at_raw,
              total_raw,
              email IS NOT NULL AND email != '' AS email_valido_flag,
              telefono IS NOT NULL AND telefono != '' AS telefono_valido_flag,
              fecha IS NOT NULL AS fecha_valida_flag,
              total_precio IS NOT NULL AS monto_valido_flag,
              product_name IS NOT NULL AND product_name != '' AS producto_valido_flag
            FROM normalized
            """,
            replacements,
        )

        sql_dim_clientes = render_sql(
            """
            CREATE OR REPLACE TABLE `__CORE_DS__.dim_clientes`
            CLUSTER BY email_principal, telefono_principal AS
            WITH orders_base AS (
              SELECT
                order_id,
                ANY_VALUE(nombre) AS nombre,
                ANY_VALUE(email) AS email,
                ANY_VALUE(telefono) AS telefono,
                ANY_VALUE(city) AS city,
                MAX(fecha) AS fecha,
                MAX(total_precio) AS total_precio
              FROM `__CORE_DS__.fact_pedidos_limpios`
              GROUP BY order_id
            ),
            normalized_orders AS (
              SELECT
                order_id,
                REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' ') AS nombre_canonico_base,
                CASE
                  WHEN ARRAY_LENGTH(SPLIT(REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' '), ' ')) >= 2 THEN
                    CONCAT(
                      SPLIT(REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' '), ' ')[OFFSET(0)],
                      ' ',
                      SPLIT(REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' '), ' ')[OFFSET(ARRAY_LENGTH(SPLIT(REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' '), ' ')) - 1)]
                    )
                  ELSE REGEXP_REPLACE(COALESCE(nombre, ''), r'\\s+', ' ')
                END AS nombre_firma_base,
                email,
                telefono,
                city,
                fecha,
                total_precio
              FROM orders_base
            ),
            phone_to_unique_email AS (
              SELECT
                telefono,
                ARRAY_AGG(DISTINCT email ORDER BY email LIMIT 1)[SAFE_OFFSET(0)] AS email_unico
              FROM normalized_orders
              WHERE telefono IS NOT NULL AND telefono != ''
                AND email IS NOT NULL AND email != ''
              GROUP BY telefono
              HAVING COUNT(DISTINCT email) = 1
            ),
            resolved_orders AS (
              SELECT
                o.order_id,
                o.nombre_canonico_base,
                o.nombre_firma_base,
                o.email,
                o.telefono,
                o.city,
                o.fecha,
                o.total_precio,
                COALESCE(o.email, p.email_unico) AS resolved_email,
                CASE
                  WHEN o.email IS NOT NULL AND o.email != '' THEN 'email'
                  WHEN p.email_unico IS NOT NULL THEN 'email_via_phone'
                  WHEN o.telefono IS NOT NULL AND o.telefono != '' THEN 'phone'
                  ELSE 'unknown'
                END AS resolved_source,
                CASE
                  WHEN COALESCE(o.email, p.email_unico) IS NOT NULL AND COALESCE(o.email, p.email_unico) != ''
                    THEN CONCAT('email:', COALESCE(o.email, p.email_unico))
                  WHEN o.telefono IS NOT NULL AND o.telefono != ''
                    THEN CONCAT('phone:', o.telefono)
                  ELSE NULL
                END AS identity_key_principal
              FROM normalized_orders o
              LEFT JOIN phone_to_unique_email p
                ON o.telefono = p.telefono
            ),
            name_counts AS (
              SELECT
                identity_key_principal,
                nombre_canonico_base,
                COUNT(*) AS nombre_count
              FROM resolved_orders
              WHERE identity_key_principal IS NOT NULL
                AND nombre_canonico_base IS NOT NULL
                AND nombre_canonico_base != ''
              GROUP BY identity_key_principal, nombre_canonico_base
            ),
            city_counts AS (
              SELECT
                identity_key_principal,
                city,
                COUNT(*) AS city_count
              FROM resolved_orders
              WHERE identity_key_principal IS NOT NULL
                AND city IS NOT NULL
                AND city != ''
              GROUP BY identity_key_principal, city
            ),
            aggregated AS (
              SELECT
                r.identity_key_principal,
                ARRAY_AGG(
                  r.resolved_source
                  ORDER BY
                    CASE
                      WHEN r.resolved_source = 'email' THEN 1
                      WHEN r.resolved_source = 'email_via_phone' THEN 2
                      WHEN r.resolved_source = 'phone' THEN 3
                      ELSE 4
                    END
                  LIMIT 1
                )[SAFE_OFFSET(0)] AS identity_source_raw,
                ARRAY_AGG(r.resolved_email IGNORE NULLS ORDER BY r.resolved_email LIMIT 1)[SAFE_OFFSET(0)] AS email_principal,
                ARRAY_AGG(r.telefono IGNORE NULLS ORDER BY r.telefono LIMIT 1)[SAFE_OFFSET(0)] AS telefono_principal,
                STRING_AGG(DISTINCT r.resolved_email, ' | ') AS emails_detectados,
                STRING_AGG(DISTINCT r.telefono, ' | ') AS telefonos_detectados,
                STRING_AGG(DISTINCT r.nombre_canonico_base, ' | ') AS nombres_detectados,
                MIN(r.fecha) AS fecha_primera_compra,
                MAX(r.fecha) AS fecha_ultima_compra,
                COUNT(DISTINCT r.order_id) AS total_compras,
                SUM(r.total_precio) AS ltv_historico,
                COUNT(DISTINCT IF(r.telefono IS NOT NULL AND r.telefono != '', r.telefono, NULL)) AS telefonos_distintos,
                COUNT(DISTINCT IF(r.nombre_firma_base IS NOT NULL AND r.nombre_firma_base != '', r.nombre_firma_base, NULL)) AS firmas_distintas,
                COUNT(DISTINCT IF(r.nombre_canonico_base IS NOT NULL AND r.nombre_canonico_base != '', r.nombre_canonico_base, NULL)) AS nombres_distintos
              FROM resolved_orders r
              WHERE r.identity_key_principal IS NOT NULL
              GROUP BY r.identity_key_principal
            ),
            best_name AS (
              SELECT
                nc.identity_key_principal,
                nc.nombre_canonico_base AS nombre_canonico
              FROM name_counts nc
              QUALIFY ROW_NUMBER() OVER (
                PARTITION BY nc.identity_key_principal
                ORDER BY nc.nombre_count DESC, LENGTH(nc.nombre_canonico_base) DESC, nc.nombre_canonico_base
              ) = 1
            ),
            best_city AS (
              SELECT
                cc.identity_key_principal,
                cc.city
              FROM city_counts cc
              QUALIFY ROW_NUMBER() OVER (
                PARTITION BY cc.identity_key_principal
                ORDER BY cc.city_count DESC, cc.city
              ) = 1
            ),
            geo_normalized AS (
              SELECT
                bc.identity_key_principal,
                bc.city AS city_raw,
                CASE
                  WHEN bc.city IS NULL OR TRIM(bc.city) = '' THEN NULL
                  WHEN TRIM(bc.city) IN ('0554', '554', '2') THEN NULL

                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) IN ('STGO', 'STGO CENTRO', 'SANTIAGO CENTRO') THEN 'SANTIAGO'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'TALCA' THEN 'TALCA'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'LAS CONDES' THEN 'LAS CONDES'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'SAN BERNARDO' THEN 'SAN BERNARDO'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'LO BARNECHEA' THEN 'LO BARNECHEA'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'NUNOA' THEN 'NUNOA'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'CONCEPCION' THEN 'CONCEPCION'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'CERRILLOS' THEN 'CERRILLOS'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'CHIGUAYANTE' THEN 'CHIGUAYANTE'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'CHILLAN' THEN 'CHILLAN'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'COLBUN' THEN 'COLBUN'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'COLINA' THEN 'COLINA'
                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) = 'BUIN' THEN 'BUIN'
                  ELSE UPPER(
                    REGEXP_REPLACE(
                      TRANSLATE(COALESCE(bc.city, ''), 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'),
                      r'\\s+',
                      ' '
                    )
                  )
                END AS comuna_principal,
                CASE
                  WHEN bc.city IS NULL OR TRIM(bc.city) = '' THEN NULL
                  WHEN TRIM(bc.city) IN ('0554', '554', '2') THEN NULL

                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) IN (
                    'TALCA',
                    'COLBUN'
                  ) THEN 'MAULE'

                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) IN (
                    'LAS CONDES',
                    'SAN BERNARDO',
                    'LO BARNECHEA',
                    'NUNOA',
                    'SANTIAGO',
                    'STGO',
                    'STGO CENTRO',
                    'SANTIAGO CENTRO',
                    'CERRILLOS',
                    'COLINA',
                    'BUIN'
                  ) THEN 'METROPOLITANA DE SANTIAGO'

                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) IN (
                    'CONCEPCION',
                    'CHIGUAYANTE'
                  ) THEN 'BIOBIO'

                  WHEN UPPER(TRIM(TRANSLATE(bc.city, 'áéíóúÁÉÍÓÚäëïöüÄËÏÖÜñÑ', 'aeiouAEIOUaeiouAEIOUnN'))) IN (
                    'CHILLAN'
                  ) THEN 'NUBLE'

                  ELSE NULL
                END AS region_principal
              FROM best_city bc
            )
            SELECT
              GENERATE_UUID() AS cliente_id,
              a.identity_key_principal,
              CASE
                WHEN a.identity_source_raw = 'email_via_phone' THEN 'email'
                ELSE a.identity_source_raw
              END AS identity_source,
              a.email_principal AS email,
              a.telefono_principal AS telefono,
              bn.nombre_canonico AS nombre,
              a.email_principal,
              a.telefono_principal,
              bn.nombre_canonico AS nombre_canonico,
              CASE
                WHEN ARRAY_LENGTH(SPLIT(COALESCE(bn.nombre_canonico, ''), ' ')) >= 2 THEN
                  CONCAT(
                    SPLIT(COALESCE(bn.nombre_canonico, ''), ' ')[OFFSET(0)],
                    ' ',
                    SPLIT(COALESCE(bn.nombre_canonico, ''), ' ')[OFFSET(ARRAY_LENGTH(SPLIT(COALESCE(bn.nombre_canonico, ''), ' ')) - 1)]
                  )
                ELSE bn.nombre_canonico
              END AS nombre_firma,
              NULL AS ciudad_principal,
              geo.comuna_principal AS comuna_principal,
              geo.region_principal AS region_principal,
              a.emails_detectados,
              a.telefonos_detectados,
              a.nombres_detectados,
              CASE
                WHEN a.identity_source_raw IN ('email', 'email_via_phone') AND a.telefonos_distintos <= 1 THEN 98
                WHEN a.identity_source_raw IN ('email', 'email_via_phone') THEN 93
                WHEN a.identity_source_raw = 'phone' AND a.firmas_distintas <= 1 THEN 88
                ELSE 75
              END AS confianza_identidad,
              CASE
                WHEN a.identity_source_raw = 'phone' AND a.firmas_distintas > 1 THEN TRUE
                WHEN a.identity_source_raw IN ('email', 'email_via_phone') AND a.firmas_distintas > 1 THEN TRUE
                WHEN a.identity_source_raw IN ('email', 'email_via_phone') AND a.telefonos_distintos > 2 THEN TRUE
                ELSE FALSE
              END AS requiere_revision,
              a.fecha_primera_compra,
              a.fecha_ultima_compra,
              a.total_compras,
              a.ltv_historico,
              CURRENT_TIMESTAMP() AS creado_el,
              CURRENT_TIMESTAMP() AS actualizado_el
            FROM aggregated a
            LEFT JOIN best_name bn
              ON a.identity_key_principal = bn.identity_key_principal
            LEFT JOIN geo_normalized geo
              ON a.identity_key_principal = geo.identity_key_principal
            """,
            replacements,
        )

        sql_bridge_identidades = render_sql(
            """
            CREATE OR REPLACE TABLE `__CORE_DS__.bridge_cliente_identidades` AS
            WITH email_rows AS (
              SELECT
                cliente_id,
                'email' AS identity_type,
                TRIM(email_val) AS identity_value,
                TRIM(email_val) = email_principal AS is_primary,
                confianza_identidad AS confidence_score,
                identity_source,
                CURRENT_TIMESTAMP() AS first_seen_at,
                CURRENT_TIMESTAMP() AS last_seen_at
              FROM `__CORE_DS__.dim_clientes`,
              UNNEST(SPLIT(COALESCE(emails_detectados, ''), ' | ')) AS email_val
              WHERE TRIM(email_val) != ''
            ),
            phone_rows AS (
              SELECT
                cliente_id,
                'phone' AS identity_type,
                TRIM(phone_val) AS identity_value,
                TRIM(phone_val) = telefono_principal AS is_primary,
                confianza_identidad AS confidence_score,
                identity_source,
                CURRENT_TIMESTAMP() AS first_seen_at,
                CURRENT_TIMESTAMP() AS last_seen_at
              FROM `__CORE_DS__.dim_clientes`,
              UNNEST(SPLIT(COALESCE(telefonos_detectados, ''), ' | ')) AS phone_val
              WHERE TRIM(phone_val) != ''
            )
            SELECT * FROM email_rows
            UNION ALL
            SELECT * FROM phone_rows
            """,
            replacements,
        )

        sql_fact_pedidos = render_sql(
            """
            CREATE OR REPLACE TABLE `__CORE_DS__.fact_pedidos`
            PARTITION BY DATE(fecha_pedido)
            CLUSTER BY cliente_id, order_id AS
            WITH orders_base AS (
              SELECT
                order_id,
                ANY_VALUE(nombre) AS nombre,
                ANY_VALUE(email) AS email,
                ANY_VALUE(telefono) AS telefono,
                ANY_VALUE(city) AS city,
                MAX(fecha) AS fecha_pedido,
                MAX(total_precio) AS total_pedido_clp,
                ANY_VALUE(source_system) AS source_system,
                ANY_VALUE(source_file) AS source_file,
                ANY_VALUE(currency_code) AS currency_code
              FROM `__CORE_DS__.fact_pedidos_limpios`
              GROUP BY order_id
            ),
            phone_to_unique_email AS (
              SELECT
                telefono,
                ARRAY_AGG(DISTINCT email ORDER BY email LIMIT 1)[SAFE_OFFSET(0)] AS email_unico
              FROM orders_base
              WHERE telefono IS NOT NULL AND telefono != ''
                AND email IS NOT NULL AND email != ''
              GROUP BY telefono
              HAVING COUNT(DISTINCT email) = 1
            ),
            resolved_orders AS (
              SELECT
                o.*,
                COALESCE(o.email, p.email_unico) AS resolved_email,
                CASE
                  WHEN o.email IS NOT NULL AND o.email != '' THEN 'email'
                  WHEN p.email_unico IS NOT NULL THEN 'email_via_phone'
                  WHEN o.telefono IS NOT NULL AND o.telefono != '' THEN 'phone'
                  ELSE 'unknown'
                END AS identity_source,
                CASE
                  WHEN COALESCE(o.email, p.email_unico) IS NOT NULL AND COALESCE(o.email, p.email_unico) != ''
                    THEN CONCAT('email:', COALESCE(o.email, p.email_unico))
                  WHEN o.telefono IS NOT NULL AND o.telefono != ''
                    THEN CONCAT('phone:', o.telefono)
                  ELSE NULL
                END AS identity_key_principal
              FROM orders_base o
              LEFT JOIN phone_to_unique_email p
                ON o.telefono = p.telefono
            )
            SELECT
              r.order_id,
              d.cliente_id,
              r.identity_key_principal,
              CASE
                WHEN r.identity_source = 'email_via_phone' THEN 'email'
                ELSE r.identity_source
              END AS identity_source,
              r.fecha_pedido,
              r.total_pedido_clp,
              r.email AS email_usado,
              r.telefono AS telefono_usado,
              r.nombre AS nombre_usado,
              r.city AS ciudad_usada,
              r.source_system,
              r.source_file,
              r.currency_code
            FROM resolved_orders r
            LEFT JOIN `__CORE_DS__.dim_clientes` d
              ON d.identity_key_principal = r.identity_key_principal
            """,
            replacements,
        )

        sql_fact_pedido_productos = render_sql(
            """
            CREATE OR REPLACE TABLE `__CORE_DS__.fact_pedido_productos`
            PARTITION BY DATE(fecha_pedido)
            CLUSTER BY cliente_id, product_name, order_id AS
            WITH line_stats AS (
              SELECT
                order_id,
                COUNTIF(product_name IS NOT NULL AND product_name != '') AS lineas_producto
              FROM `__CORE_DS__.fact_pedidos_limpios`
              GROUP BY order_id
            )
            SELECT
              f.order_id,
              fp.cliente_id,
              f.fecha AS fecha_pedido,
              f.product_name,
              COALESCE(f.cantidad, 1) AS cantidad,
              CASE
                WHEN f.subtotal_linea IS NOT NULL THEN f.subtotal_linea
                WHEN f.precio_unitario IS NOT NULL THEN f.precio_unitario * COALESCE(f.cantidad, 1)
                WHEN ls.lineas_producto = 1 THEN f.total_precio
                ELSE NULL
              END AS precio_linea_clp,
              CASE
                WHEN f.subtotal_linea IS NULL
                     AND f.precio_unitario IS NULL
                     AND ls.lineas_producto = 1
                  THEN TRUE
                ELSE FALSE
              END AS precio_linea_inferida_flag,
              f.precio_unitario,
              f.sku,
              f.product_id,
              f.variant_id,
              f.vendor,
              f.product_type,
              f.source_system,
              f.source_file,
              f.currency_code
            FROM `__CORE_DS__.fact_pedidos_limpios` f
            LEFT JOIN `__CORE_DS__.fact_pedidos` fp
              ON f.order_id = fp.order_id
            LEFT JOIN line_stats ls
              ON f.order_id = ls.order_id
            """,
            replacements,
        )

        query_steps = [
            ("core.fact_pedidos_limpios", sql_fact_pedidos_limpios),
            ("core.dim_clientes", sql_dim_clientes),
            ("core.bridge_cliente_identidades", sql_bridge_identidades),
            ("core.fact_pedidos", sql_fact_pedidos),
            ("core.fact_pedido_productos", sql_fact_pedido_productos),
        ]

        for step_name, sql in query_steps:
            run_query(bq, step_name, sql)

        write_done_marker(
            storage_client=storage_client,
            bucket_name=bucket_name,
            done_key=done_key,
            payload=f"done:{file_name}:{generation}",
        )

        logging.info("EXITO CORE: %s procesado correctamente.", brand_id)
        publish_brand_event(PROJECT_ID, PUBSUB_TOPIC_ID, brand_id)

    except Exception as e:
        logging.exception("ERROR CRITICO procesando %s: %s", file_name, str(e))
        raise

