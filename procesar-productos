import base64
import functions_framework
from google.cloud import bigquery

BQ_LOCATION = "US"

@functions_framework.cloud_event
def procesar_productos(cloud_event):
    brand_id = base64.b64decode(cloud_event.data["message"]["data"]).decode("utf-8")
    bq = bigquery.Client()

    sql = f"""
    CREATE OR REPLACE TABLE `{bq.project}.{brand_id}_ai.resumen_productos_retencion` AS
    WITH product_events AS (
      SELECT
        cliente_id,
        product_name,
        order_id,
        fecha_pedido,
        precio_linea_clp
      FROM `{bq.project}.{brand_id}_core.fact_pedido_productos`
      WHERE cliente_id IS NOT NULL
        AND product_name IS NOT NULL AND product_name != ''
    ),
    product_customer AS (
      SELECT
        product_name,
        cliente_id,
        COUNT(DISTINCT order_id) AS compras_producto,
        MIN(fecha_pedido) AS primera_compra_producto,
        MAX(fecha_pedido) AS ultima_compra_producto
      FROM product_events
      GROUP BY product_name, cliente_id
    ),
    any_next_order AS (
      SELECT
        pc.product_name,
        pc.cliente_id,
        pc.compras_producto,
        EXISTS (
          SELECT 1
          FROM `{bq.project}.{brand_id}_core.fact_pedidos` fp
          WHERE fp.cliente_id = pc.cliente_id
            AND fp.fecha_pedido > pc.primera_compra_producto
        ) AS recompra_cualquier_cosa
      FROM product_customer pc
    ),
    ordered_repeats AS (
      SELECT
        product_name,
        cliente_id,
        fecha_pedido,
        LEAD(fecha_pedido) OVER (
          PARTITION BY product_name, cliente_id
          ORDER BY fecha_pedido
        ) AS next_fecha
      FROM product_events
    ),
    recompra_days AS (
      SELECT
        product_name,
        cliente_id,
        AVG(TIMESTAMP_DIFF(next_fecha, fecha_pedido, DAY)) AS dias_hasta_recompra
      FROM ordered_repeats
      WHERE next_fecha IS NOT NULL
      GROUP BY product_name, cliente_id
    ),
    sales AS (
      SELECT
        product_name,
        COUNT(DISTINCT cliente_id) AS clientes_unicos,
        AVG(precio_linea_clp) AS ticket_promedio_producto
      FROM product_events
      GROUP BY product_name
    )
    SELECT
      p.product_name,
      s.clientes_unicos,
      COUNT(DISTINCT CASE WHEN p.compras_producto >= 2 THEN p.cliente_id END) AS clientes_que_recompran_producto,
      SAFE_DIVIDE(
        COUNT(DISTINCT CASE WHEN p.compras_producto >= 2 THEN p.cliente_id END),
        NULLIF(COUNT(DISTINCT p.cliente_id), 0)
      ) AS repeat_rate_producto,
      COUNT(DISTINCT CASE WHEN p.recompra_cualquier_cosa THEN p.cliente_id END) AS clientes_que_vuelven_a_comprar_cualquier_cosa,
      SAFE_DIVIDE(
        COUNT(DISTINCT CASE WHEN p.recompra_cualquier_cosa THEN p.cliente_id END),
        NULLIF(COUNT(DISTINCT p.cliente_id), 0)
      ) AS retention_rate_post_producto,
      s.ticket_promedio_producto,
      AVG(r.dias_hasta_recompra) AS dias_promedio_recompra_producto,
      CASE
        WHEN SAFE_DIVIDE(
          COUNT(DISTINCT CASE WHEN p.recompra_cualquier_cosa THEN p.cliente_id END),
          NULLIF(COUNT(DISTINCT p.cliente_id), 0)
        ) >= 0.40 THEN 'ALTA_RETENCION'
        WHEN SAFE_DIVIDE(
          COUNT(DISTINCT CASE WHEN p.compras_producto >= 2 THEN p.cliente_id END),
          NULLIF(COUNT(DISTINCT p.cliente_id), 0)
        ) >= 0.30 THEN 'ALTA_RECOMPRA'
        WHEN s.ticket_promedio_producto >= (
          SELECT AVG(precio_linea_clp)
          FROM `{bq.project}.{brand_id}_core.fact_pedido_productos`
          WHERE precio_linea_clp IS NOT NULL
        )
        AND SAFE_DIVIDE(
          COUNT(DISTINCT CASE WHEN p.recompra_cualquier_cosa THEN p.cliente_id END),
          NULLIF(COUNT(DISTINCT p.cliente_id), 0)
        ) < 0.15 THEN 'ALTO_TICKET_BAJA_RETENCION'
        WHEN SAFE_DIVIDE(
          COUNT(DISTINCT CASE WHEN p.recompra_cualquier_cosa THEN p.cliente_id END),
          NULLIF(COUNT(DISTINCT p.cliente_id), 0)
        ) >= 0.25 THEN 'PRODUCTO_GANCHO'
        ELSE 'PRODUCTO_DE_UNA_SOLA_VEZ'
      END AS clasificacion_retencion
    FROM any_next_order p
    LEFT JOIN recompra_days r
      ON p.product_name = r.product_name
     AND p.cliente_id = r.cliente_id
    LEFT JOIN sales s
      ON p.product_name = s.product_name
    GROUP BY p.product_name, s.clientes_unicos, s.ticket_promedio_producto
    """
    bq.query(sql, location=BQ_LOCATION).result()
    print(f"✅ resumen de productos actualizado para {brand_id}")
