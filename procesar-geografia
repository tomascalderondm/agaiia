import base64
import functions_framework
from google.cloud import bigquery

BQ_LOCATION = "US"

@functions_framework.cloud_event
def procesar_clientes(cloud_event):
    brand_id = base64.b64decode(cloud_event.data["message"]["data"]).decode("utf-8")
    bq = bigquery.Client()

    sql = f"""
    CREATE OR REPLACE TABLE `{bq.project}.{brand_id}_ai.perfil_clientes_360` AS
    WITH contexto AS (
      SELECT MAX(fecha) AS fecha_max_global
      FROM `{bq.project}.{brand_id}_core.fact_pedidos_limpios`
    )
    SELECT
      c.cliente_id,
      c.nombre,
      c.email,
      c.telefono,
      c.total_compras,
      c.ltv_historico,
      DATE_DIFF(CURRENT_DATE(), DATE(c.fecha_ultima_compra), DAY) AS dias_inactividad,
      CASE
        WHEN DATE(c.fecha_primera_compra) >= DATE_SUB(DATE(cx.fecha_max_global), INTERVAL 3 MONTH) THEN 'CLIENTE NUEVO'
        WHEN c.total_compras >= 3 THEN 'CLIENTE CAMPEON'
        WHEN DATE_DIFF(CURRENT_DATE(), DATE(c.fecha_ultima_compra), DAY) > 90 THEN 'CLIENTE EN RIESGO'
        ELSE 'CLIENTE ACTIVO'
      END AS segmento_valor
    FROM `{bq.project}.{brand_id}_core.dim_clientes` c
    CROSS JOIN contexto cx
    """
    bq.query(sql, location=BQ_LOCATION).result()
    print(f"✅ perfil_clientes_360 actualizado para {brand_id}")


